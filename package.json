{
  "name": "@aniketjha348/supercoder",
  "version": "1.0.0",
  "description": "Your AI's own software development team - 100+ specialized AI agents for complete software engineering",
  "bin": {
    "supercoder": "./bin/supercoder.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "postinstall": "node bin/supercoder.js npm-install",
    "install:codex": "node bin/supercoder.js install codex",
    "install:claude": "node bin/supercoder.js install claude",
    "install:opencode": "node bin/supercoder.js install opencode",
    "install:cursor": "node bin/supercoder.js install cursor",
    "install:windsurf": "node bin/supercoder.js install windsurf",
    "install:gemini": "node bin/supercoder.js install gemini",
    "install:trae": "node bin/supercoder.js install trae",
    "list": "node bin/supercoder.js list",
    "clean": "node bin/supercoder.js clean"
  },
  "keywords": [
    "supercoder",
    "ai",
    "software-development",
    "agent",
    "team",
    "codex",
    "claude-code",
    "opencode",
    "cursor",
    "windsurf",
    "workflow",
    "tdd",
    "ai-coding",
    "development-team"
  ],
  "author": "aniketjha348",
  "license": "MIT",
  "homepage": "https://github.com/aniketjha348/Supercoder",
  "repository": {
    "type": "git",
    "url": "https://github.com/aniketjha348/Supercoder.git"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
